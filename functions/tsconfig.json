{
  "compilerOptions": {
    "module": "NodeNext",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "types": ["jest", "node"]
  },
  "compileOnSave": true,
  "include": [
    "src"
  ],
  "exclude": [
    "src/__tests__"
  ]
}
